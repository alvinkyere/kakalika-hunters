# ─────────────────────────────────────────
# Sanctuary — Environment Variables
# ─────────────────────────────────────────
# DO NOT commit this file to GitHub.
# Add .env to your .gitignore immediately.
# Share keys with teammates via a secure
# channel (1Password, Bitwarden, etc.)
# ─────────────────────────────────────────

# AssemblyAI — real-time transcription
# Get your key at: https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# DeepL — translation
# Get your key at: https://www.deepl.com/pro-api
# Free tier: use api-free.deepl.com (already set in translate.js)
# Paid tier: change hostname in translate.js to api.deepl.com
DEEPL_API_KEY=your_deepl_key_here

# Server port (optional, defaults to 4000 if not set)
PORT=4000

# URL where the React frontend is running
FRONTEND_URL=http://localhost:3000